{
  "name": "ptt-web-backend",
  "version": "1.0.0",
  "description": "Backend simples para PTT Web com contatos e presença online",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "peer": "peerjs --port 9000 --key peerjs --path /peerjs",
    "dev": "concurrently \"npm run peer\" \"npm start\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.4",
    "peer": "^1.0.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
